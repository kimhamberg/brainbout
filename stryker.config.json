{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "testRunner": "command",
  "commandRunner": {
    "command": "FAST_CHECK_NUM_RUNS=10 bun test --bail"
  },
  "coverageAnalysis": "off",
  "mutate": [
    "src/chess960.ts",
    "src/hub.ts",
    "src/hub-render.ts",
    "src/games/crown-clock.ts",
    "src/games/crown-logic.ts",
    "src/games/flux-engine.ts",
    "src/games/flux-render.ts",
    "src/games/lex-logic.ts",
    "src/games/lex-srs.ts",
    "src/shared/assert.ts",
    "src/shared/icons.ts",
    "src/shared/progress.ts",
    "src/shared/rng.ts",
    "src/shared/sounds.ts",
    "src/shared/stages.ts",
    "src/shared/theme.ts",
    "src/shared/think-time.ts",
    "src/shared/timer.ts"
  ],
  "ignorePatterns": [
    "/dist",
    "/public/sounds",
    "/public/stockfish",
    "/android",
    "/docs",
    "/games",
    "/ref-sounds",
    "/.dict-cache",
    "/coverage",
    "/reports",
    "/test/e2e",
    "/playwright-report",
    "/test-results"
  ],
  "disableTypeChecks": "{src,test}/**/*.ts",
  "incremental": true,
  "incrementalFile": "reports/stryker-incremental.json",
  "thresholds": { "high": 90, "low": 70, "break": 65 },
  "concurrency": 4,
  "timeoutMS": 30000,
  "reporters": ["progress", "clear-text", "html"],
  "htmlReporter": { "fileName": "reports/mutation/index.html" }
}
