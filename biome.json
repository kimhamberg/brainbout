{
  "$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": [
      "src/**/*.ts",
      "test/**/*.ts",
      "scripts/**/*.ts",
      "server/**/*.ts",
      "!server/embed.gen.ts",
      "*.ts",
      "*.js",
      "*.json"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": false,
      "a11y": "on",
      "complexity": "on",
      "correctness": "on",
      "performance": "on",
      "security": "on",
      "style": "on",
      "suspicious": "on",
      "nursery": "on"
    }
  },
  "javascript": {
    "globals": ["Bun"],
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "always",
      "trailingCommas": "all"
    }
  },
  "css": {
    "linter": { "enabled": false },
    "formatter": { "enabled": false }
  },
  "overrides": [
    {
      "includes": ["**"],
      "linter": {
        "rules": {
          "complexity": {
            "useLiteralKeys": "off",
            "useMaxParams": "off",
            "noExcessiveCognitiveComplexity": "off",
            "noExcessiveLinesPerFunction": "off",
            "noVoid": "off"
          },
          "style": {
            "noMagicNumbers": "off",
            "noNonNullAssertion": "off",
            "useNamingConvention": "off",
            "useConsistentMemberAccessibility": "off",
            "useExportsLast": "off",
            "noNestedTernary": "off",
            "useDefaultSwitchClause": "off"
          },
          "performance": {
            "useTopLevelRegex": "off",
            "noNamespaceImport": "off",
            "noAwaitInLoops": "off"
          },
          "nursery": {
            "noContinue": "off",
            "noIncrementDecrement": "off",
            "noTernary": "off",
            "useExplicitReturnType": "off",
            "useExplicitType": "off",
            "useNamedCaptureGroup": "off",
            "useGlobalThis": "off",
            "useDestructuring": "off",
            "noExcessiveLinesPerFile": "off",
            "useDomQuerySelector": "off",
            "noPlaywrightWaitForTimeout": "off"
          },
          "security": {
            "noSecrets": "off"
          },
          "suspicious": {
            "noConsole": "off"
          },
          "correctness": {
            "useQwikValidLexicalScope": "off"
          }
        }
      }
    },
    {
      "includes": ["scripts/**", "server/**", "vite.config.ts", "test/**"],
      "linter": {
        "rules": {
          "correctness": {
            "noNodejsModules": "off"
          },
          "style": {
            "noDefaultExport": "off"
          },
          "nursery": {
            "noConditionalExpect": "off"
          }
        }
      }
    }
  ],
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  }
}
