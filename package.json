{
  "name": "brainbout",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "bun scripts/dev.ts",
    "build": "bun scripts/build.ts",
    "build:server": "bun run build && bun server/build.ts",
    "build:linux": "bun run build && bun server/build.ts brainbout-linux-amd64",
    "build:windows": "bun run build && bun server/build.ts brainbout-windows-amd64.exe",
    "build:android": "bun run build && rm -rf android/app/src/main/assets && mkdir -p android/app/src/main/assets && cp -r dist/. android/app/src/main/assets/ && cd android && ./gradlew assembleDebug",
    "test": "bun test",
    "test:cov": "bun test --coverage",
    "test:watch": "bun test --watch",
    "test:fuzz": "FAST_CHECK_NUM_RUNS=100000 bun test test/property.test.ts",
    "test:e2e": "playwright test",
    "test:mutation": "stryker run",
    "check": "biome check",
    "check:fix": "biome check --write",
    "lint": "bun scripts/lint.ts",
    "lint:css": "stylelint \"src/**/*.css\"",
    "lint:html": "superhtml check index.html games/*.html",
    "lint:kt": "ktlint \"android/**/*.kt\"",
    "clean": "rm -rf dist brainbout brainbout-linux-amd64 brainbout-windows-amd64.exe brainbout.apk",
    "screenshot": "bun scripts/screenshot.ts",
    "download:dict": "bun scripts/download-dictionaries.ts",
    "gen:icons": "bun scripts/gen-icons.ts"
  },
  "dependencies": {
    "@lichess-org/chessground": "^10.0.2"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@biomejs/biome": "^2.4.15",
    "@happy-dom/global-registrator": "^20.9.0",
    "@playwright/test": "^1.60.0",
    "@stryker-mutator/core": "^9.6.1",
    "@typescript/native-preview": "^7.0.0-dev.20260513.1",
    "bun-types": "^1.3.14",
    "fast-check": "^4.8.0",
    "lefthook": "^2.1.6",
    "playwright": "^1.60.0",
    "sharp": "^0.34.5",
    "stylelint": "^17.4.0",
    "stylelint-config-clean-order": "^8.0.1",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-declaration-block-no-ignored-properties": "^3.0.0",
    "stylelint-media-use-custom-media": "^4.1.0",
    "stylelint-order": "^7.0.1",
    "stylelint-scales": "^5.0.0",
    "stylelint-use-nesting": "^6.0.2",
    "stylelint-value-no-unknown-custom-properties": "^6.1.1",
    "typescript": "^5.9.3"
  },
  "license": "GPL-3.0"
}
